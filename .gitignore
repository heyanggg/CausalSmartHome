# =========================
# CausalSmartHome .gitignore
# =========================

# ---- Python cache / test cache ----
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.cache/
.ipynb_checkpoints/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# ---- Virtual environments / local env files ----
.env
.env.*
!.env.example
.venv/
venv/
env/
ENV/
conda-meta/

# ---- Packaging / build artifacts ----
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# ---- IDE / OS files ----
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ---- Raw datasets / generated datasets ----
data/
dataset/
datasets/
raw_data/
processed_data/
IoT_data/
**/IoT_data/
synthetic_data/
**/synthetic_data/
anomaly_detection_pipeline/synthetic_data/

# Smart-home sequence/data files generated or consumed by experiments.
*.pkl
*.pickle
*.npy
*.npz
*.h5
*.hdf5
*.mat
*.csv
*.tsv

# ---- Model checkpoints / training artifacts ----
checkpoints/
checkpoint/
ckpt/
saved_models/
models/checkpoints/
*.pt
*.pth
*.ckpt
*.onnx
*.joblib

# ---- Experiment outputs / logs ----
artifacts/
outputs/
results/
result/
runs/
logs/
log/
wandb/
mlruns/
lightning_logs/
tensorboard/
*.log
*_RESULT
*_result
*_results

# ---- Temporary files / archives ----
tmp/
temp/
*.tmp
*.bak
*.tar
*.tar.gz
*.tgz
*.zip
*.7z
core_py_projects_*.tar.gz

# ---- Local notes / paper PDFs not needed in the public code repo ----
论文缝合与实现.txt
*.pdf

# ---- Optional: keep placeholder files ----
!.gitkeep

# ---- Vendored SmartGen artifacts required for reproducibility ----
!causal_smart_home/resources/gen_data/**/*.pkl
!causal_smart_home/gen_core/anomaly_detection_pipeline/attack/**/*.pkl
!causal_smart_home/gen_core/anomaly_detection_pipeline/test/**/*.pkl
!causal_smart_home/gen_core/anomaly_detection_pipeline/synthetic_data/**/*.pkl
!causal_smart_home/gen_core/anomaly_detection_pipeline/check_model/*.pth
!causal_smart_home/gen_core/gen_original_tof/check_model/*.pth

!outputs/
outputs/*
!outputs/reference_gen/
!outputs/reference_gen/**

# large generated files / experiment artifacts
outputs/
runs/
wandb/
checkpoints/
models/
*.pt
*.pth
*.ckpt
*.pkl
*.pickle
*.npy
*.npz
*.csv
*.log
*.tar
*.tar.gz
*.zip
*.7z

# cache / env
__pycache__/
.pytest_cache/
.mypy_cache/
.venv/
venv/
smartguard_env/
